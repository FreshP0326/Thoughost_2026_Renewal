generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Reserved scaffolding only: the rendered site currently reads from src/content/**
// through src/server/services/** during static export, not from this schema.
datasource db {
  provider = "sqlite"
}

model SiteConfig {
  id            String @id @default(cuid())
  defaultLocale String @default("en")
  contactEmail  String
  copyrightText String
  footerQuoteEn String
  footerQuoteZh String
  footerQuoteJa String
}

model NavigationLink {
  id        String @id @default(cuid())
  key       String
  labelEn   String
  labelZh   String
  labelJa   String
  href      String
  sortOrder Int
  location  String
}

model SocialLink {
  id        String @id @default(cuid())
  platform  String
  label     String
  url       String
  iconKey   String
  sortOrder Int
}

model HeroProject {
  id         String  @id @default(cuid())
  slug       String  @unique
  titleEn    String
  titleZh    String
  titleJa    String
  subtitleEn String?
  subtitleZh String?
  subtitleJa String?
  ctaLabelEn String
  ctaLabelZh String
  ctaLabelJa String
  ctaHref    String
  leftImage  String
  mainImage  String
  rightImage String
  isActive   Boolean @default(true)
  sortOrder  Int     @default(0)
}

model NewsItem {
  id        String   @id @default(cuid())
  slug      String   @unique
  date      DateTime
  titleEn   String
  titleZh   String
  titleJa   String
  summaryEn String?
  summaryZh String?
  summaryJa String?
  href      String
  isPinned  Boolean  @default(false)
  published Boolean  @default(true)
}

model Release {
  id          String        @id @default(cuid())
  slug        String        @unique
  titleEn     String
  titleZh     String
  titleJa     String
  artistName  String
  releaseType String
  releaseDate DateTime
  coverImage  String
  heroImage   String?
  summaryEn   String
  summaryZh   String
  summaryJa   String
  tracklistEn Json
  tracklistZh Json
  tracklistJa Json
  isFeatured  Boolean       @default(false)
  sortOrder   Int           @default(0)
  published   Boolean       @default(true)
  links       ReleaseLink[]
}

model ReleaseLink {
  id        String  @id @default(cuid())
  platform  String
  url       String
  sortOrder Int     @default(0)
  releaseId String
  release   Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)
}

model PageContent {
  id      String @id @default(cuid())
  pageKey String @unique
  titleEn String
  titleZh String
  titleJa String
  bodyEn  String
  bodyZh  String
  bodyJa  String
}

model ProjectItem {
  id         String  @id @default(cuid())
  slug       String  @unique
  titleEn    String
  titleZh    String
  titleJa    String
  summaryEn  String
  summaryZh  String
  summaryJa  String
  coverImage String
  href       String
  published  Boolean @default(true)
  sortOrder  Int     @default(0)
}
